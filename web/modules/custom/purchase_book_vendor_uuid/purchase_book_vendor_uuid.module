<?php

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_entity_presave().
 */
function purchase_book_vendor_uuid_entity_presave(EntityInterface $entity) {

  // Only act on nodes.
  if ($entity->getEntityTypeId() !== 'node') {
    return;
  }

  // Only for purchase_book content type.
  if ($entity->bundle() !== 'purchase_book') {
    return;
  }

  // Ensure vendor field exists and has value.
  if (!$entity->hasField('field_vendor') || $entity->get('field_vendor')->isEmpty()) {
    return;
  }

  // Get referenced vendor entity.
  $vendor = $entity->get('field_vendor')->entity;

  if ($vendor && $vendor->bundle() === 'vendor') {

    // Set UUID field automatically.
    if ($entity->hasField('field_vendor_uuid')) {
      $entity->set('field_vendor_uuid', $vendor->uuid());
    }
  }
}




use Drupal\Core\Form\FormStateInterface;

/**
 * Make vendor UUID field read-only on purchase_book form.
 */
function purchase_book_vendor_uuid_form_node_purchase_book_form_alter(&$form, FormStateInterface $form_state) {
  _purchase_book_vendor_uuid_make_readonly($form);
}

function purchase_book_vendor_uuid_form_node_purchase_book_edit_form_alter(&$form, FormStateInterface $form_state) {
  _purchase_book_vendor_uuid_make_readonly($form);
}

function _purchase_book_vendor_uuid_make_readonly(&$form) {

  if (isset($form['field_vendor_uuid']['widget'][0]['value'])) {

    // Make field hidden
    $form['field_vendor_uuid']['widget'][0]['value']['#attributes']['hidden'] = 'hidden';

    // Make field hidden
    $form['field_sold_quantity_in_unit']['widget'][0]['value']['#attributes']['hidden'] = 'hidden';

    // Make field readonly
    $form['field_balance_stock']['widget'][0]['value']['#attributes']['readonly'] = 'readonly';

    // Optional: add visual style
    $form['field_vendor_uuid']['widget'][0]['value']['#attributes']['style'] = 'background-color:#f5f5f5;';

    // Optional: add visual style
    $form['field_balance_stock']['widget'][0]['value']['#attributes']['style'] = 'background-color:#f5f5f5;';
  }
}